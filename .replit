# Replit deployment source of truth:
# run/build/start use the unified root entrypoint. Do not re-split status-page and api-server into separate public services.
modules = ["nodejs-24"]
run = "pnpm dev"

[deployment]
build = "pnpm run build"
run = "pnpm start"
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[gitHubImport]
requiredFiles = [".replit", "package.json", "pnpm-workspace.yaml"]

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[[ports]]
localPort = 3000
externalPort = 80
